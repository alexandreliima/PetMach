<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Brand -->
    <Color x:Key="PetMachPrimary">#C94F3D</Color>
    <Color x:Key="PetMachPrimaryDark">#A83D30</Color>
    <Color x:Key="PetMachPrimarySoft">#FBE8E3</Color>
    <Color x:Key="PetMachSecondary">#176B68</Color>
    <Color x:Key="PetMachSecondaryDark">#0F514F</Color>
    <Color x:Key="PetMachSecondarySoft">#E1F0ED</Color>

    <!-- Foundation -->
    <Color x:Key="PetMachBackground">#FFF8F2</Color>
    <Color x:Key="PetMachSurface">#FFFFFF</Color>
    <Color x:Key="PetMachSurfaceMuted">#F5EFEA</Color>
    <Color x:Key="PetMachSurfaceStrong">#243B39</Color>
    <Color x:Key="PetMachTextPrimary">#202927</Color>
    <Color x:Key="PetMachTextSecondary">#626C69</Color>
    <Color x:Key="PetMachTextOnColor">#FFFFFF</Color>
    <Color x:Key="PetMachTextOnStrong">#F4F8F7</Color>
    <Color x:Key="PetMachPlaceholder">#858D8A</Color>
    <Color x:Key="PetMachBorder">#E4DAD2</Color>
    <Color x:Key="PetMachDivider">#EEE6E0</Color>
    <Color x:Key="PetMachDisabled">#B5BAB8</Color>
    <Color x:Key="PetMachDisabledSurface">#ECE9E6</Color>
    <Color x:Key="PetMachShadowColor">#243B39</Color>

    <!-- Feedback -->
    <Color x:Key="PetMachSuccess">#2F7658</Color>
    <Color x:Key="PetMachSuccessSoft">#E4F2EA</Color>
    <Color x:Key="PetMachWarning">#94631D</Color>
    <Color x:Key="PetMachWarningSoft">#FFF1D6</Color>
    <Color x:Key="PetMachError">#B64039</Color>
    <Color x:Key="PetMachErrorSoft">#FBE7E5</Color>
    <Color x:Key="PetMachInfo">#356B8C</Color>
    <Color x:Key="PetMachInfoSoft">#E5F0F7</Color>

    <!-- Compatibility aliases for pages not migrated in this increment. -->
    <Color x:Key="Primary">#C94F3D</Color>
    <Color x:Key="PrimaryDark">#A83D30</Color>
    <Color x:Key="Surface">#FFF8F2</Color>
    <Color x:Key="SurfaceCard">#FFFFFF</Color>
    <Color x:Key="SurfaceMuted">#F5EFEA</Color>
    <Color x:Key="TextPrimary">#202927</Color>
    <Color x:Key="TextSecondary">#626C69</Color>
    <Color x:Key="Border">#E4DAD2</Color>
    <Color x:Key="Teal">#176B68</Color>
    <Color x:Key="Mint">#E1F0ED</Color>
    <Color x:Key="Amber">#94631D</Color>
    <Color x:Key="Danger">#B64039</Color>
</ResourceDictionary>
