<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style x:Key="PetMachDisplayStyle" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="38" />
        <Setter Property="LineHeight" Value="1.05" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextPrimary}" />
    </Style>

    <Style x:Key="PetMachPageTitleStyle" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="30" />
        <Setter Property="LineHeight" Value="1.1" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextPrimary}" />
    </Style>

    <Style x:Key="PetMachSectionTitleStyle" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="20" />
        <Setter Property="LineHeight" Value="1.15" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextPrimary}" />
    </Style>

    <Style x:Key="PetMachCardTitleStyle" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="18" />
        <Setter Property="LineHeight" Value="1.15" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextPrimary}" />
    </Style>

    <Style x:Key="PetMachBodyStyle" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="LineHeight" Value="1.25" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextPrimary}" />
    </Style>

    <Style x:Key="PetMachBodySmallStyle" TargetType="Label">
        <Setter Property="FontSize" Value="14" />
        <Setter Property="LineHeight" Value="1.25" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextSecondary}" />
    </Style>

    <Style x:Key="PetMachCaptionStyle" TargetType="Label">
        <Setter Property="FontSize" Value="12" />
        <Setter Property="LineHeight" Value="1.2" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextSecondary}" />
    </Style>

    <Style x:Key="PetMachEyebrowStyle" TargetType="Label">
        <Setter Property="CharacterSpacing" Value="1.4" />
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="12" />
        <Setter Property="TextColor" Value="{StaticResource PetMachPrimary}" />
    </Style>

    <Style x:Key="PetMachButtonTextStyle" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextOnColor}" />
    </Style>

    <Style x:Key="PetMachInputTextStyle" TargetType="Label">
        <Setter Property="FontSize" Value="16" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextPrimary}" />
    </Style>

    <Style x:Key="PetMachFieldLabelStyle" TargetType="Label">
        <Setter Property="FontAttributes" Value="Bold" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextPrimary}" />
    </Style>

    <Style x:Key="PetMachErrorTextStyle" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="1.2" />
        <Setter Property="TextColor" Value="{StaticResource PetMachError}" />
    </Style>

    <Style x:Key="PetMachSuccessTextStyle" TargetType="Label">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="1.2" />
        <Setter Property="TextColor" Value="{StaticResource PetMachSuccess}" />
    </Style>

    <!-- Compatibility keys. -->
    <Style x:Key="PageTitle" TargetType="Label" BasedOn="{StaticResource PetMachPageTitleStyle}" />
    <Style x:Key="SectionTitle" TargetType="Label" BasedOn="{StaticResource PetMachSectionTitleStyle}" />
    <Style x:Key="Caption" TargetType="Label" BasedOn="{StaticResource PetMachCaptionStyle}" />
</ResourceDictionary>
