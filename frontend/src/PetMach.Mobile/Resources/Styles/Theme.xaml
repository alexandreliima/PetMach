<?xml version="1.0" encoding="utf-8" ?>
<ResourceDictionary
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <Style TargetType="ContentPage">
        <Setter Property="BackgroundColor" Value="{StaticResource PetMachBackground}" />
    </Style>

    <Style TargetType="Label">
        <Setter Property="TextColor" Value="{StaticResource PetMachTextPrimary}" />
    </Style>

    <Style TargetType="Button" BasedOn="{StaticResource PetMachPrimaryButtonStyle}" />

    <Style TargetType="Entry">
        <Setter Property="BackgroundColor" Value="{StaticResource PetMachSurface}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="HeightRequest" Value="{StaticResource PetMachInputHeight}" />
        <Setter Property="PlaceholderColor" Value="{StaticResource PetMachPlaceholder}" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextPrimary}" />
    </Style>

    <Style TargetType="Editor">
        <Setter Property="BackgroundColor" Value="{StaticResource PetMachSurface}" />
        <Setter Property="FontSize" Value="16" />
        <Setter Property="PlaceholderColor" Value="{StaticResource PetMachPlaceholder}" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextPrimary}" />
    </Style>

    <Style TargetType="Picker">
        <Setter Property="BackgroundColor" Value="{StaticResource PetMachSurface}" />
        <Setter Property="HeightRequest" Value="{StaticResource PetMachInputHeight}" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextPrimary}" />
        <Setter Property="TitleColor" Value="{StaticResource PetMachPlaceholder}" />
    </Style>

    <Style TargetType="DatePicker">
        <Setter Property="BackgroundColor" Value="{StaticResource PetMachSurface}" />
        <Setter Property="HeightRequest" Value="{StaticResource PetMachInputHeight}" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextPrimary}" />
    </Style>

    <Style TargetType="TimePicker">
        <Setter Property="BackgroundColor" Value="{StaticResource PetMachSurface}" />
        <Setter Property="HeightRequest" Value="{StaticResource PetMachInputHeight}" />
        <Setter Property="TextColor" Value="{StaticResource PetMachTextPrimary}" />
    </Style>

    <Style TargetType="CheckBox">
        <Setter Property="Color" Value="{StaticResource PetMachPrimary}" />
    </Style>

    <Style TargetType="ActivityIndicator" BasedOn="{StaticResource PetMachLoadingIndicatorStyle}" />

    <Style TargetType="Border">
        <Setter Property="Stroke" Value="{StaticResource PetMachBorder}" />
        <Setter Property="StrokeThickness" Value="{StaticResource PetMachBorderWidth}" />
    </Style>
</ResourceDictionary>
