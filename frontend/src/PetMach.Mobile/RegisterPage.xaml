<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PetMach.Mobile.RegisterPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:sys="clr-namespace:System;assembly=System.Runtime"
    Title="Criar conta">
    <ScrollView>
        <VerticalStackLayout Padding="28,24,28,32" Spacing="13">
            <Image
                HeightRequest="58"
                HorizontalOptions="Center"
                Source="petmatch_logo.svg"
                WidthRequest="58" />
            <Label
                FontAttributes="Bold"
                FontSize="30"
                HorizontalTextAlignment="Center"
                Text="Crie sua conta" />
            <Label
                HorizontalTextAlignment="Center"
                Margin="0,-6,0,10"
                Text="Comece uma nova história com seu melhor amigo."
                TextColor="{StaticResource TextSecondary}" />

            <Label FontAttributes="Bold" Text="E-mail" />
            <Border BackgroundColor="#FFFCF9" Padding="12,0" StrokeShape="RoundRectangle 12">
                <Entry BackgroundColor="Transparent" Keyboard="Email" Placeholder="seu@email.com" Text="{Binding Email}" />
            </Border>

            <Label FontAttributes="Bold" Text="Senha" />
            <Border BackgroundColor="#FFFCF9" Padding="12,0" StrokeShape="RoundRectangle 12">
                <Entry BackgroundColor="Transparent" IsPassword="True" Placeholder="Mínimo de 12 caracteres" Text="{Binding Password}" />
            </Border>

            <Label FontAttributes="Bold" Text="Data de nascimento" />
            <Border BackgroundColor="#FFFCF9" Padding="12,0" StrokeShape="RoundRectangle 12">
                <DatePicker BackgroundColor="Transparent" Date="{Binding BirthDate}" MaximumDate="{x:Static sys:DateTime.Today}" />
            </Border>

            <Border BackgroundColor="{StaticResource SurfaceMuted}" Padding="12" StrokeThickness="0" StrokeShape="RoundRectangle 14">
                <VerticalStackLayout Spacing="7">
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <CheckBox Color="{StaticResource Primary}" IsChecked="{Binding AcceptedTerms}" />
                        <Label Grid.Column="1" FontSize="13" Text="Aceito os Termos de Uso" VerticalTextAlignment="Center" />
                    </Grid>
                    <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                        <CheckBox Color="{StaticResource Primary}" IsChecked="{Binding AcceptedPrivacy}" />
                        <Label Grid.Column="1" FontSize="13" Text="Aceito a Política de Privacidade" VerticalTextAlignment="Center" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Label HorizontalTextAlignment="Center" Text="{Binding StatusMessage}" TextColor="{StaticResource Danger}" />
            <ActivityIndicator Color="{StaticResource Primary}" IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />
            <Button Command="{Binding RegisterCommand}" Text="Criar conta" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
