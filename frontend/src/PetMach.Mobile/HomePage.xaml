<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PetMach.Mobile.HomePage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:PetMach.Mobile.Components"
    Shell.NavBarIsVisible="False">
    <Grid>
        <components:StateView
            Margin="{StaticResource PetMachPagePadding}"
            HorizontalOptions="Fill"
            IsVisible="{Binding Presentation.IsLoading, Source={x:Reference RootPage}}"
            Kind="Loading"
            Message="Organizando novidades, encontros e cuidados para você."
            SemanticProperties.Description="Carregando a página inicial"
            Title="Preparando sua experiência"
            VerticalOptions="Center" />

        <VerticalStackLayout
            Margin="{StaticResource PetMachPagePadding}"
            IsVisible="{Binding Presentation.HasError, Source={x:Reference RootPage}}"
            Spacing="{StaticResource PetMachSpace16}"
            VerticalOptions="Center">
            <components:StateView
                Kind="Error"
                Message="{Binding Presentation.ErrorMessage, Source={x:Reference RootPage}}"
                SemanticProperties.Description="Não foi possível carregar a página inicial"
                Title="Algo não saiu como esperado" />
            <Button
                AutomationId="HomeRetryButton"
                Clicked="RetryClicked"
                SemanticProperties.Hint="Tenta carregar a página inicial novamente"
                Style="{StaticResource PetMachPrimaryButtonStyle}"
                Text="Tentar novamente" />
        </VerticalStackLayout>

        <ScrollView
            x:Name="HomeScroll"
            IsVisible="{Binding Presentation.ShowContent, Source={x:Reference RootPage}}">
            <VerticalStackLayout
                x:Name="HomeContent"
                Padding="24,32,24,36"
                Spacing="{StaticResource PetMachSpace24}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource PetMachSpace12}">
                    <components:SectionHeaderView
                        Eyebrow="SUA ROTINA PETMACH"
                        Subtitle="Um resumo leve do que importa hoje."
                        Title="Olá! Que bom ter você aqui." />
                    <Button
                        Grid.Column="1"
                        AutomationId="HomeNotificationsButton"
                        Command="{Binding OpenNotificationsCommand}"
                        HeightRequest="{StaticResource PetMachTouchTarget}"
                        SemanticProperties.Hint="Abre suas notificações"
                        Style="{StaticResource PetMachGhostButtonStyle}"
                        Text="Avisos" />
                </Grid>

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Seu companheiro" />

                    <Border
                        AutomationId="HomePrimaryPetCard"
                        IsVisible="{Binding Presentation.HasPrimaryPet, Source={x:Reference RootPage}}"
                        Style="{StaticResource PetMachStrongCardStyle}">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource PetMachSpace16}">
                            <components:PetAvatarView
                                SemanticProperties.Description="Foto do pet principal"
                                Size="88"
                                Source="{Binding Presentation.PrimaryPet.ImageSource, Source={x:Reference RootPage}}" />
                            <VerticalStackLayout Grid.Column="1" Spacing="{StaticResource PetMachSpace4}">
                                <Label
                                    Style="{StaticResource PetMachCardTitleStyle}"
                                    Text="{Binding Presentation.PrimaryPet.Name, Source={x:Reference RootPage}}"
                                    TextColor="{StaticResource PetMachTextOnColor}" />
                                <Label
                                    Style="{StaticResource PetMachBodySmallStyle}"
                                    TextColor="{StaticResource PetMachTextOnStrong}">
                                    <Label.FormattedText>
                                        <FormattedString>
                                            <Span Text="{Binding Presentation.PrimaryPet.Breed, Source={x:Reference RootPage}}" />
                                            <Span Text=" · " />
                                            <Span Text="{Binding Presentation.PrimaryPet.Age, Source={x:Reference RootPage}}" />
                                        </FormattedString>
                                    </Label.FormattedText>
                                </Label>
                                <Label
                                    Style="{StaticResource PetMachCaptionStyle}"
                                    Text="{Binding Presentation.PrimaryPet.Description, Source={x:Reference RootPage}}"
                                    TextColor="{StaticResource PetMachTextOnStrong}" />
                                <Button
                                    AutomationId="HomeManagePetsButton"
                                    Command="{Binding OpenDogsCommand}"
                                    HorizontalOptions="Start"
                                    SemanticProperties.Hint="Abre os perfis dos seus pets"
                                    Style="{StaticResource PetMachGhostButtonStyle}"
                                    Text="Ver perfil"
                                    TextColor="{StaticResource PetMachTextOnColor}" />
                            </VerticalStackLayout>
                        </Grid>
                    </Border>

                    <VerticalStackLayout
                        IsVisible="{Binding Presentation.HasNoPrimaryPet, Source={x:Reference RootPage}}"
                        Spacing="{StaticResource PetMachSpace12}">
                        <components:StateView
                            Kind="Empty"
                            Message="Cadastre um pet para personalizar matches, cuidados e recomendações."
                            Title="Comece pelo perfil do seu pet" />
                        <Button
                            AutomationId="HomeAddPetButton"
                            Command="{Binding OpenDogsCommand}"
                            SemanticProperties.Hint="Abre o cadastro e gerenciamento de pets"
                            Style="{StaticResource PetMachPrimaryButtonStyle}"
                            Text="Cadastrar pet" />
                    </VerticalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Ações rápidas" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="{StaticResource PetMachSpace12}" RowDefinitions="Auto,Auto" RowSpacing="{StaticResource PetMachSpace12}">
                        <Border Style="{StaticResource PetMachCardStyle}">
                            <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                                <Label FontSize="24" Text="♡" TextColor="{StaticResource PetMachPrimary}" />
                                <Label Style="{StaticResource PetMachCardTitleStyle}" Text="Descobrir" />
                                <Button
                                    AutomationId="HomeDiscoverButton"
                                    Command="{Binding OpenDiscoveryCommand}"
                                    SemanticProperties.Hint="Abre a descoberta de pets"
                                    Style="{StaticResource PetMachGhostButtonStyle}"
                                    Text="Explorar" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Column="1" Style="{StaticResource PetMachCardStyle}">
                            <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                                <Label FontSize="24" Text="○" TextColor="{StaticResource PetMachSecondary}" />
                                <Label Style="{StaticResource PetMachCardTitleStyle}" Text="Matches" />
                                <Button
                                    AutomationId="HomeMatchesButton"
                                    Command="{Binding OpenMatchesCommand}"
                                    SemanticProperties.Hint="Abre seus matches"
                                    Style="{StaticResource PetMachGhostButtonStyle}"
                                    Text="Ver todos" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Row="1" Style="{StaticResource PetMachCardStyle}">
                            <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                                <Label FontSize="24" Text="□" TextColor="{StaticResource PetMachPrimary}" />
                                <Label Style="{StaticResource PetMachCardTitleStyle}" Text="Agenda" />
                                <Button
                                    AutomationId="HomeMeetingsButton"
                                    Command="{Binding OpenMeetingsCommand}"
                                    SemanticProperties.Hint="Abre seus encontros"
                                    Style="{StaticResource PetMachGhostButtonStyle}"
                                    Text="Encontros" />
                            </VerticalStackLayout>
                        </Border>
                        <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource PetMachCardStyle}">
                            <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                                <Label FontSize="24" Text="⌂" TextColor="{StaticResource PetMachSecondary}" />
                                <Label Style="{StaticResource PetMachCardTitleStyle}" Text="Parceiros" />
                                <Button
                                    AutomationId="HomePartnersButton"
                                    Command="{Binding OpenPartnerSpacesCommand}"
                                    SemanticProperties.Hint="Abre espaços e serviços parceiros"
                                    Style="{StaticResource PetMachGhostButtonStyle}"
                                    Text="Encontrar" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            SemanticProperties.HeadingLevel="Level2"
                            Style="{StaticResource PetMachSectionTitleStyle}"
                            Text="Matches recentes" />
                        <Button
                            Grid.Column="1"
                            Command="{Binding OpenMatchesCommand}"
                            Style="{StaticResource PetMachGhostButtonStyle}"
                            Text="Ver todos" />
                    </Grid>
                    <CollectionView
                        AutomationId="HomeRecentMatches"
                        HeightRequest="146"
                        IsVisible="{Binding Presentation.HasRecentMatches, Source={x:Reference RootPage}}"
                        ItemsSource="{Binding Presentation.RecentMatches, Source={x:Reference RootPage}}"
                        ItemsLayout="HorizontalList"
                        SelectionMode="None">
                        <CollectionView.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,12,0" MinimumWidthRequest="170" Style="{StaticResource PetMachCardStyle}">
                                    <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                                        <components:PetAvatarView Size="48" />
                                        <Label Style="{StaticResource PetMachCardTitleStyle}" Text="{Binding Name}" />
                                        <Label Style="{StaticResource PetMachCaptionStyle}" Text="{Binding Breed}" />
                                        <Label Style="{StaticResource PetMachSuccessTextStyle}" Text="{Binding Status}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </CollectionView.ItemTemplate>
                    </CollectionView>
                    <components:StateView
                        IsVisible="{Binding Presentation.HasNoRecentMatches, Source={x:Reference RootPage}}"
                        Kind="Empty"
                        Message="Explore novos perfis para criar conexões."
                        Title="Nenhum match por enquanto" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Grid ColumnDefinitions="*,Auto">
                        <Label
                            SemanticProperties.HeadingLevel="Level2"
                            Style="{StaticResource PetMachSectionTitleStyle}"
                            Text="Próximos compromissos" />
                        <Button
                            Grid.Column="1"
                            Command="{Binding OpenReservationsCommand}"
                            Style="{StaticResource PetMachGhostButtonStyle}"
                            Text="Reservas" />
                    </Grid>
                    <VerticalStackLayout
                        BindableLayout.ItemsSource="{Binding Presentation.UpcomingAppointments, Source={x:Reference RootPage}}"
                        IsVisible="{Binding Presentation.HasUpcomingAppointments, Source={x:Reference RootPage}}"
                        Spacing="{StaticResource PetMachSpace8}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PetMachCardStyle}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource PetMachSpace12}">
                                        <VerticalStackLayout Spacing="{StaticResource PetMachSpace4}">
                                            <Label Style="{StaticResource PetMachCardTitleStyle}" Text="{Binding Title}" />
                                            <Label Style="{StaticResource PetMachBodySmallStyle}" Text="{Binding Place}" />
                                        </VerticalStackLayout>
                                        <Border Grid.Column="1" Style="{StaticResource PetMachSelectedChipStyle}">
                                            <Label Style="{StaticResource PetMachBadgeLabelStyle}" Text="{Binding Schedule}" TextColor="{StaticResource PetMachPrimary}" />
                                        </Border>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    <components:StateView
                        IsVisible="{Binding Presentation.HasNoUpcomingAppointments, Source={x:Reference RootPage}}"
                        Kind="Empty"
                        Message="Seus encontros, passeios e reservas aparecerão aqui."
                        Title="Agenda livre" />
                </VerticalStackLayout>

                <VerticalStackLayout
                    IsVisible="{Binding Presentation.HasFeaturedPartner, Source={x:Reference RootPage}}"
                    Spacing="{StaticResource PetMachSpace12}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Parceiro em destaque" />
                    <Border Style="{StaticResource PetMachCardStyle}">
                        <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                            <Border HorizontalOptions="Start" Style="{StaticResource PetMachSelectedChipStyle}">
                                <Label Style="{StaticResource PetMachBadgeLabelStyle}" Text="PET FRIENDLY" TextColor="{StaticResource PetMachPrimary}" />
                            </Border>
                            <Label Style="{StaticResource PetMachCardTitleStyle}" Text="{Binding Presentation.FeaturedPartner.Name, Source={x:Reference RootPage}}" />
                            <Label Style="{StaticResource PetMachBodySmallStyle}" Text="{Binding Presentation.FeaturedPartner.Description, Source={x:Reference RootPage}}" />
                            <Label Style="{StaticResource PetMachCaptionStyle}" Text="{Binding Presentation.FeaturedPartner.Highlights, Source={x:Reference RootPage}}" />
                            <Button
                                AutomationId="HomeFeaturedPartnerButton"
                                Command="{Binding OpenPartnerSpacesCommand}"
                                SemanticProperties.Hint="Abre os espaços parceiros"
                                Style="{StaticResource PetMachSecondaryButtonStyle}"
                                Text="Conhecer espaços" />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Recomendado para você" />
                    <Border Style="{StaticResource PetMachCardStyle}">
                        <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                            <Label Style="{StaticResource PetMachCardTitleStyle}" Text="Cuidados em dia, encontros mais seguros" />
                            <Label Style="{StaticResource PetMachBodySmallStyle}" Text="Mantenha as informações de saúde do seu pet organizadas." />
                            <Button
                                AutomationId="HomeHealthButton"
                                Command="{Binding OpenHealthCommand}"
                                SemanticProperties.Hint="Abre a área de saúde do pet"
                                Style="{StaticResource PetMachSecondaryButtonStyle}"
                                Text="Ver saúde e cuidados" />
                        </VerticalStackLayout>
                    </Border>
                    <Button
                        AutomationId="HomeAdoptionButton"
                        Command="{Binding OpenAdoptionCommand}"
                        SemanticProperties.Hint="Abre a área de adoção responsável"
                        Style="{StaticResource PetMachGhostButtonStyle}"
                        Text="Conhecer adoção responsável" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                    <Label Style="{StaticResource PetMachSectionTitleStyle}" Text="Conta e serviços" />
                    <Button Command="{Binding OpenConversationsCommand}" Style="{StaticResource PetMachSecondaryButtonStyle}" Text="Conversas" />
                    <Button Command="{Binding OpenTutorProfileCommand}" Style="{StaticResource PetMachSecondaryButtonStyle}" Text="Perfil do tutor" />
                    <Button
                        AutomationId="HomeSettingsButton"
                        Command="{Binding OpenSettingsCommand}"
                        SemanticProperties.Hint="Abre as configurações da conta e do aplicativo"
                        Style="{StaticResource PetMachSecondaryButtonStyle}"
                        Text="Configurações" />
                    <Button Command="{Binding OpenPartnerOperationsCommand}" Style="{StaticResource PetMachGhostButtonStyle}" Text="Área do parceiro" />
                    <Button
                        AutomationId="HomeLogoutButton"
                        Command="{Binding LogoutCommand}"
                        SemanticProperties.Hint="Encerra sua sessão no PetMatch"
                        Style="{StaticResource PetMachDestructiveButtonStyle}"
                        Text="Sair da conta" />
                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
