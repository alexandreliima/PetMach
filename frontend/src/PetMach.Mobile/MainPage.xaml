<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PetMach.Mobile.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="{AppThemeBinding Light={StaticResource Surface}, Dark=#201C1A}"
    Shell.NavBarIsVisible="False">
    <ScrollView>
        <VerticalStackLayout Padding="32,64,32,32" Spacing="20">
            <Label
                FontAttributes="Bold"
                FontSize="14"
                Text="PETMACH"
                TextColor="{StaticResource Primary}" />
            <Label
                FontAttributes="Bold"
                FontSize="42"
                SemanticProperties.HeadingLevel="Level1"
                Text="Amizades, passeios e cuidado para o seu cão."
                TextColor="{AppThemeBinding Light={StaticResource TextPrimary}, Dark=White}" />
            <Image
                Aspect="AspectFit"
                HeightRequest="155"
                HorizontalOptions="Fill"
                SemanticProperties.Description="Dois cães felizes lado a lado, um macho e uma fêmea"
                Source="petmach_welcome_dogs.png" />
            <Label
                FontSize="18"
                LineHeight="1.4"
                Text="Encontre boas companhias e experiências seguras perto de você."
                TextColor="{AppThemeBinding Light=#6B5E56, Dark=#D7C9C0}" />
            <Button
                Command="{Binding OpenRegistrationCommand}"
                CornerRadius="18"
                HeightRequest="56"
                Text="Criar minha conta" />
            <Button
                BackgroundColor="Transparent"
                BorderColor="{StaticResource Primary}"
                BorderWidth="1"
                Command="{Binding OpenLoginCommand}"
                CornerRadius="18"
                HeightRequest="56"
                Text="Já tenho uma conta"
                TextColor="{StaticResource Primary}" />
            <Button
                BackgroundColor="Transparent"
                Command="{Binding OpenAboutCommand}"
                FontAttributes="Bold"
                Text="Conhecer o PetMach"
                TextColor="#6B5E56" />
            <Label
                FontSize="13"
                HorizontalTextAlignment="Center"
                Text="Socialização responsável • Privacidade • Segurança"
                TextColor="{AppThemeBinding Light=#7A6D65, Dark=#D7C9C0}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
