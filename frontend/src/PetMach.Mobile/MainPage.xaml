<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PetMach.Mobile.MainPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Shell.NavBarIsVisible="False">
    <Grid BackgroundColor="{StaticResource PetMachBackground}">
        <Grid
            x:Name="SplashContent"
            Padding="{StaticResource PetMachPagePadding}">
            <VerticalStackLayout
                x:Name="SplashBrand"
                HorizontalOptions="Center"
                Spacing="{StaticResource PetMachSpace16}"
                VerticalOptions="Center">
                <Border
                    BackgroundColor="{StaticResource PetMachSurface}"
                    HeightRequest="132"
                    Padding="{StaticResource PetMachSpace20}"
                    Stroke="{StaticResource PetMachPrimarySoft}"
                    StrokeShape="RoundRectangle 44"
                    StrokeThickness="2"
                    WidthRequest="132">
                    <Image
                        x:Name="SplashLogo"
                        Aspect="AspectFit"
                        SemanticProperties.Description="Logotipo PetMatch"
                        Source="petmatch_logo.svg" />
                </Border>
                <Label
                    HorizontalTextAlignment="Center"
                    SemanticProperties.HeadingLevel="Level1"
                    Style="{StaticResource PetMachDisplayStyle}">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Pet" TextColor="{StaticResource PetMachTextPrimary}" />
                            <Span Text="Match" TextColor="{StaticResource PetMachPrimary}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
                <Label
                    HorizontalTextAlignment="Center"
                    Style="{StaticResource PetMachBodyStyle}"
                    Text="Conexões que fazem rabos abanarem."
                    TextColor="{StaticResource PetMachTextSecondary}" />
                <ActivityIndicator
                    x:Name="SplashIndicator"
                    Margin="0,12,0,0"
                    IsRunning="True"
                    SemanticProperties.Description="Carregando o PetMatch"
                    Style="{StaticResource PetMachLoadingIndicatorStyle}" />
            </VerticalStackLayout>
            <Grid.GestureRecognizers>
                <TapGestureRecognizer Tapped="AdvanceTapped" />
            </Grid.GestureRecognizers>
        </Grid>

        <Grid
            x:Name="OnboardingContent"
            IsVisible="False"
            Opacity="0"
            Padding="24,24,24,28"
            RowDefinitions="Auto,*,Auto,Auto">
            <Grid ColumnDefinitions="*,Auto">
                <Image
                    HeightRequest="44"
                    HorizontalOptions="Start"
                    SemanticProperties.Description="PetMatch"
                    Source="petmatch_logo.svg"
                    WidthRequest="44" />
                <Button
                    Grid.Column="1"
                    Command="{Binding OpenLoginCommand}"
                    SemanticProperties.Hint="Vai diretamente para a tela de login"
                    Style="{StaticResource PetMachGhostButtonStyle}"
                    Text="Pular" />
            </Grid>

            <CarouselView
                x:Name="OnboardingCarousel"
                Grid.Row="1"
                IndicatorView="{x:Reference OnboardingIndicator}"
                ItemsSource="{Binding OnboardingItems, Source={x:Reference RootPage}}"
                PositionChanged="OnboardingPositionChanged">
                <CarouselView.ItemTemplate>
                    <DataTemplate>
                        <ScrollView>
                            <VerticalStackLayout
                                Padding="0,16,0,12"
                                Spacing="{StaticResource PetMachSpace20}">
                                <Border
                                    BackgroundColor="{StaticResource PetMachSurface}"
                                    HeightRequest="300"
                                    Padding="0"
                                    Style="{StaticResource PetMachCardStyle}">
                                    <Image
                                        Aspect="{Binding ImageAspect}"
                                        SemanticProperties.Description="{Binding ImageDescription}"
                                        Source="{Binding ImageSource}" />
                                </Border>

                                <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                                    <Label
                                        HorizontalTextAlignment="Center"
                                        SemanticProperties.HeadingLevel="Level1"
                                        Style="{StaticResource PetMachPageTitleStyle}"
                                        Text="{Binding Title}" />
                                    <Label
                                        HorizontalTextAlignment="Center"
                                        Style="{StaticResource PetMachBodyStyle}"
                                        Text="{Binding Description}"
                                        TextColor="{StaticResource PetMachTextSecondary}" />
                                </VerticalStackLayout>

                                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="{StaticResource PetMachSpace8}">
                                    <Border Style="{StaticResource PetMachChipStyle}">
                                        <Label
                                            HorizontalTextAlignment="Center"
                                            Style="{StaticResource PetMachBadgeLabelStyle}"
                                            Text="{Binding FeatureOne}" />
                                    </Border>
                                    <Border Grid.Column="1" Style="{StaticResource PetMachSelectedChipStyle}">
                                        <Label
                                            HorizontalTextAlignment="Center"
                                            Style="{StaticResource PetMachBadgeLabelStyle}"
                                            Text="{Binding FeatureTwo}"
                                            TextColor="{StaticResource PetMachPrimary}" />
                                    </Border>
                                    <Border Grid.Column="2" Style="{StaticResource PetMachChipStyle}">
                                        <Label
                                            HorizontalTextAlignment="Center"
                                            Style="{StaticResource PetMachBadgeLabelStyle}"
                                            Text="{Binding FeatureThree}" />
                                    </Border>
                                </Grid>
                            </VerticalStackLayout>
                        </ScrollView>
                    </DataTemplate>
                </CarouselView.ItemTemplate>
            </CarouselView>

            <IndicatorView
                x:Name="OnboardingIndicator"
                Grid.Row="2"
                HorizontalOptions="Center"
                IndicatorColor="{StaticResource PetMachBorder}"
                IndicatorSize="9"
                MaximumVisible="3"
                SelectedIndicatorColor="{StaticResource PetMachPrimary}" />

            <Grid Grid.Row="3" Margin="0,16,0,0">
                <Button
                    x:Name="NextButton"
                    Clicked="NextClicked"
                    SemanticProperties.Hint="Avança para a próxima apresentação"
                    Style="{StaticResource PetMachPrimaryButtonStyle}"
                    Text="Próximo" />
                <Button
                    x:Name="StartButton"
                    Command="{Binding OpenLoginCommand}"
                    IsVisible="False"
                    SemanticProperties.Hint="Abre a tela de login"
                    Style="{StaticResource PetMachPrimaryButtonStyle}"
                    Text="Começar" />
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
