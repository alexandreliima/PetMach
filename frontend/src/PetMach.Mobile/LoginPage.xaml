<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PetMach.Mobile.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:PetMach.Mobile.Components"
    Shell.NavBarIsVisible="False"
    Title="Entrar">
    <ScrollView>
        <VerticalStackLayout
            x:Name="LoginContent"
            MaximumWidthRequest="520"
            Padding="24,36,24,32"
            Spacing="{StaticResource PetMachSpace20}">
            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource PetMachSpace12}">
                <Border
                    BackgroundColor="{StaticResource PetMachSurface}"
                    HeightRequest="64"
                    Padding="{StaticResource PetMachSpace8}"
                    Stroke="{StaticResource PetMachPrimarySoft}"
                    StrokeShape="RoundRectangle 22"
                    StrokeThickness="2"
                    WidthRequest="64">
                    <Image
                        SemanticProperties.Description="Logotipo PetMatch"
                        Source="petmatch_logo.svg" />
                </Border>
                <components:SectionHeaderView
                    Grid.Column="1"
                    Eyebrow="BEM-VINDO DE VOLTA"
                    Subtitle="Entre para continuar cuidando das suas conexões."
                    Title="Acesse sua conta" />
            </Grid>

            <Border Style="{StaticResource PetMachCardStyle}">
                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                        <Label Style="{StaticResource PetMachFieldLabelStyle}" Text="E-mail" />
                        <Border Style="{StaticResource PetMachInputContainerStyle}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource PetMachSpace8}">
                                <Label
                                    FontSize="18"
                                    SemanticProperties.Description="E-mail"
                                    Text="✉"
                                    TextColor="{StaticResource PetMachPlaceholder}"
                                    VerticalTextAlignment="Center" />
                                <Entry
                                    Grid.Column="1"
                                    AutomationId="LoginEmailEntry"
                                    ClearButtonVisibility="WhileEditing"
                                    Keyboard="Email"
                                    Placeholder="seu@email.com"
                                    ReturnType="Next"
                                    SemanticProperties.Description="Digite seu e-mail"
                                    Style="{StaticResource PetMachInputEntryStyle}"
                                    Text="{Binding Email}" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                        <Label Style="{StaticResource PetMachFieldLabelStyle}" Text="Senha" />
                        <Border Style="{StaticResource PetMachInputContainerStyle}">
                            <Grid ColumnDefinitions="Auto,*" ColumnSpacing="{StaticResource PetMachSpace8}">
                                <Label
                                    FontSize="16"
                                    SemanticProperties.Description="Senha"
                                    Text="●"
                                    TextColor="{StaticResource PetMachPlaceholder}"
                                    VerticalTextAlignment="Center" />
                                <Entry
                                    Grid.Column="1"
                                    AutomationId="LoginPasswordEntry"
                                    IsPassword="True"
                                    Placeholder="Sua senha"
                                    ReturnType="Go"
                                    SemanticProperties.Description="Digite sua senha"
                                    Style="{StaticResource PetMachInputEntryStyle}"
                                    Text="{Binding Password}" />
                            </Grid>
                        </Border>
                    </VerticalStackLayout>

                    <Button
                        HorizontalOptions="End"
                        SemanticProperties.Hint="Recuperação de senha ainda não disponível"
                        Style="{StaticResource PetMachGhostButtonStyle}"
                        Text="Esqueci minha senha" />

                    <components:StateView
                        Kind="Loading"
                        Message="Validando seus dados com segurança."
                        IsVisible="{Binding IsBusy}"
                        Title="Entrando" />

                    <components:StateView
                        x:Name="LoginFeedback"
                        Kind="Error"
                        Message="{Binding StatusMessage}"
                        IsVisible="False"
                        Title="Não foi possível entrar" />

                    <Button
                        AutomationId="LoginButton"
                        Command="{Binding LoginCommand}"
                        SemanticProperties.Hint="Entra na sua conta PetMatch"
                        Style="{StaticResource PetMachPrimaryButtonStyle}"
                        Text="Entrar">
                        <Button.Triggers>
                            <DataTrigger Binding="{Binding IsBusy}" TargetType="Button" Value="True">
                                <Setter Property="IsEnabled" Value="False" />
                            </DataTrigger>
                        </Button.Triggers>
                    </Button>
                </VerticalStackLayout>
            </Border>

            <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="{StaticResource PetMachSpace12}">
                <BoxView Color="{StaticResource PetMachDivider}" HeightRequest="1" VerticalOptions="Center" />
                <Label Grid.Column="1" Style="{StaticResource PetMachCaptionStyle}" Text="ainda não tem uma conta?" />
                <BoxView Grid.Column="2" Color="{StaticResource PetMachDivider}" HeightRequest="1" VerticalOptions="Center" />
            </Grid>

            <Button
                AutomationId="OpenRegistrationButton"
                Clicked="OpenRegistrationClicked"
                SemanticProperties.Hint="Abre o cadastro de uma nova conta"
                Style="{StaticResource PetMachSecondaryButtonStyle}"
                Text="Criar conta" />

            <Border HorizontalOptions="Center" Style="{StaticResource PetMachChipStyle}">
                <HorizontalStackLayout Spacing="{StaticResource PetMachSpace8}">
                    <Label Text="✓" TextColor="{StaticResource PetMachSuccess}" />
                    <Label Style="{StaticResource PetMachCaptionStyle}" Text="Sua sessão é protegida e seus dados são privados." />
                </HorizontalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
