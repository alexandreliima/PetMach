<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PetMach.Mobile.DiscoveryPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:PetMach.Mobile.Components"
    BackgroundColor="{StaticResource PetMachBackground}"
    Shell.NavBarIsVisible="False"
    Title="Descobrir">
    <Grid
        Padding="{StaticResource PetMachPagePadding}"
        RowDefinitions="Auto,Auto,*,Auto,Auto"
        RowSpacing="{StaticResource PetMachSpace12}">
        <Grid ColumnDefinitions="*,Auto" VerticalOptions="Center">
            <HorizontalStackLayout Spacing="{StaticResource PetMachSpace8}">
                <Image
                    HeightRequest="{StaticResource PetMachIconMedium}"
                    SemanticProperties.Description="Logotipo PetMatch"
                    Source="petmatch_logo.svg"
                    WidthRequest="{StaticResource PetMachIconMedium}" />
                <Label
                    SemanticProperties.HeadingLevel="Level1"
                    Style="{StaticResource PetMachPageTitleStyle}"
                    VerticalTextAlignment="Center">
                    <Label.FormattedText>
                        <FormattedString>
                            <Span Text="Pet" />
                            <Span Text="Match" TextColor="{StaticResource PetMachPrimary}" />
                        </FormattedString>
                    </Label.FormattedText>
                </Label>
            </HorizontalStackLayout>
            <Button
                Grid.Column="1"
                AutomationId="DiscoveryFiltersButton"
                Command="{Binding ToggleFiltersCommand}"
                SemanticProperties.Description="Filtros da descoberta"
                SemanticProperties.Hint="Mostra ou oculta os filtros disponíveis"
                Style="{StaticResource PetMachGhostButtonStyle}"
                Text="Filtros" />
        </Grid>

        <VerticalStackLayout
            Grid.Row="1"
            Spacing="{StaticResource PetMachSpace12}">
            <VerticalStackLayout Spacing="{StaticResource PetMachSpace4}">
                <Label
                    Style="{StaticResource PetMachFieldLabelStyle}"
                    Text="Pet de origem" />
                <Picker
                    x:Name="SourceDogPicker"
                    AutomationId="DiscoverySourceDogPicker"
                    ItemDisplayBinding="{Binding Name}"
                    ItemsSource="{Binding MyDogs}"
                    SelectedIndexChanged="SourceDogChanged"
                    SelectedItem="{Binding SelectedDog, Mode=OneWay}"
                    SemanticProperties.Description="Pet selecionado para descobrir novos amigos"
                    SemanticProperties.Hint="Trocar o pet reinicia as sugestões"
                    Title="Escolha seu pet para descobrir" />
            </VerticalStackLayout>

            <Border
                AutomationId="DiscoveryFiltersPanel"
                IsVisible="{Binding ShowFilters}"
                Style="{StaticResource PetMachCardStyle}">
                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Filtros" />
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="{StaticResource PetMachSpace8}">
                        <Entry
                            AutomationId="DiscoveryBreedFilter"
                            Placeholder="Raça"
                            SemanticProperties.Description="Filtrar por raça"
                            Text="{Binding BreedFilter}" />
                        <Picker
                            Grid.Column="1"
                            AutomationId="DiscoverySizeFilter"
                            ItemsSource="{Binding SizeOptions}"
                            SelectedItem="{Binding SizeFilter}"
                            SemanticProperties.Description="Filtrar por porte"
                            Title="Porte" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="{StaticResource PetMachSpace8}">
                        <Picker
                            AutomationId="DiscoverySexFilter"
                            ItemsSource="{Binding SexOptions}"
                            SelectedItem="{Binding SexFilter}"
                            SemanticProperties.Description="Filtrar por sexo"
                            Title="Sexo" />
                        <Picker
                            Grid.Column="1"
                            AutomationId="DiscoveryEnergyFilter"
                            ItemsSource="{Binding EnergyOptions}"
                            SelectedItem="{Binding EnergyLevelFilter}"
                            SemanticProperties.Description="Filtrar por nível de energia"
                            Title="Energia" />
                    </Grid>
                    <Picker
                        AutomationId="DiscoveryGoalFilter"
                        ItemsSource="{Binding GoalOptions}"
                        SelectedItem="{Binding GoalFilter}"
                        SemanticProperties.Description="Filtrar por objetivo"
                        Title="Objetivo" />
                    <Grid
                        ColumnDefinitions="*,Auto,*,Auto"
                        ColumnSpacing="{StaticResource PetMachSpace8}">
                        <Label
                            Style="{StaticResource PetMachBodySmallStyle}"
                            Text="Castrado"
                            VerticalTextAlignment="Center" />
                        <Switch
                            Grid.Column="1"
                            AutomationId="DiscoveryNeuteredFilter"
                            IsToggled="{Binding OnlyNeutered}"
                            SemanticProperties.Description="Mostrar somente pets castrados" />
                        <Label
                            Grid.Column="2"
                            Style="{StaticResource PetMachBodySmallStyle}"
                            Text="Vacinação em dia"
                            VerticalTextAlignment="Center" />
                        <Switch
                            Grid.Column="3"
                            AutomationId="DiscoveryVaccinationFilter"
                            IsToggled="{Binding OnlyVaccinated}"
                            SemanticProperties.Description="Mostrar somente pets com vacinação em dia" />
                    </Grid>
                    <Grid ColumnDefinitions="*,*" ColumnSpacing="{StaticResource PetMachSpace8}">
                        <Button
                            AutomationId="DiscoveryApplyFiltersButton"
                            Command="{Binding RefreshCommand}"
                            SemanticProperties.Hint="Recarrega as sugestões com os filtros selecionados"
                            Style="{StaticResource PetMachPrimaryButtonStyle}"
                            Text="Aplicar filtros" />
                        <Button
                            Grid.Column="1"
                            AutomationId="DiscoveryClearFiltersButton"
                            Command="{Binding ClearFiltersCommand}"
                            SemanticProperties.Hint="Remove todos os filtros e recarrega as sugestões"
                            Style="{StaticResource PetMachSecondaryButtonStyle}"
                            Text="Limpar filtros" />
                    </Grid>
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>

        <components:StateView
            Grid.Row="2"
            AutomationId="DiscoveryInitialState"
            IsVisible="{Binding IsInitialState}"
            Kind="Loading"
            Message="Preparando a descoberta para o pet selecionado."
            SemanticProperties.Description="Preparando a descoberta"
            Title="Preparando descoberta"
            VerticalOptions="Center" />

        <components:StateView
            Grid.Row="2"
            AutomationId="DiscoveryLoadingState"
            IsVisible="{Binding IsLoadingState}"
            Kind="Loading"
            Message="Buscando novos amigos com os critérios selecionados."
            SemanticProperties.Description="Carregando sugestões de pets"
            Title="Procurando novos pets"
            VerticalOptions="Center" />

        <VerticalStackLayout
            Grid.Row="2"
            IsVisible="{Binding IsEmptyState}"
            Spacing="{StaticResource PetMachSpace16}"
            VerticalOptions="Center">
            <components:StateView
                AutomationId="DiscoveryEmptyState"
                Kind="Empty"
                Message="{Binding EmptyMessage}"
                SemanticProperties.Description="{Binding EmptyMessage}"
                Title="Nenhuma sugestão agora" />
            <Button
                AutomationId="DiscoveryEmptyClearFiltersButton"
                Command="{Binding ClearFiltersCommand}"
                IsVisible="{Binding HasActiveFilters}"
                SemanticProperties.Hint="Remove os filtros e procura novamente"
                Style="{StaticResource PetMachSecondaryButtonStyle}"
                Text="Limpar filtros" />
        </VerticalStackLayout>

        <VerticalStackLayout
            Grid.Row="2"
            IsVisible="{Binding IsErrorState}"
            Spacing="{StaticResource PetMachSpace16}"
            VerticalOptions="Center">
            <components:StateView
                AutomationId="DiscoveryErrorState"
                Kind="Error"
                Message="{Binding ErrorMessage}"
                SemanticProperties.Description="{Binding ErrorMessage}"
                Title="Não foi possível carregar" />
            <Button
                AutomationId="DiscoveryRetryButton"
                Command="{Binding RetryCommand}"
                SemanticProperties.Hint="Tenta carregar as sugestões novamente"
                Style="{StaticResource PetMachPrimaryButtonStyle}"
                Text="Tentar novamente" />
        </VerticalStackLayout>

        <CollectionView
            Grid.Row="2"
            AutomationId="DiscoveryCandidates"
            IsVisible="{Binding IsContentState}"
            ItemsSource="{Binding Candidates}"
            RemainingItemsThreshold="2"
            RemainingItemsThresholdReachedCommand="{Binding LoadMoreCommand}"
            SemanticProperties.Description="Sugestões de pets disponíveis">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <VerticalStackLayout
                        Margin="{StaticResource PetMachSpace8}"
                        Spacing="{StaticResource PetMachSpace12}">
                        <Border
                            BackgroundColor="{StaticResource PetMachSurfaceMuted}"
                            HeightRequest="470"
                            Padding="0"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 28">
                            <Grid>
                                <Image
                                    Aspect="AspectFill"
                                    SemanticProperties.Description="{Binding Name, StringFormat='Foto principal de {0}'}"
                                    Source="{Binding PrimaryPhotoUrl, TargetNullValue=petmach_welcome_dogs.png}" />
                                <BoxView
                                    BackgroundColor="{StaticResource PetMachSurfaceStrong}"
                                    HeightRequest="210"
                                    Opacity="0.86"
                                    VerticalOptions="End" />
                                <Border
                                    Margin="{StaticResource PetMachSpace16}"
                                    BackgroundColor="{StaticResource PetMachSurface}"
                                    HorizontalOptions="Start"
                                    Padding="{StaticResource PetMachChipPadding}"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    VerticalOptions="Start">
                                    <Label
                                        Style="{StaticResource PetMachBadgeLabelStyle}"
                                        Text="Novo por aqui"
                                        TextColor="{StaticResource PetMachPrimary}" />
                                </Border>
                                <VerticalStackLayout
                                    Margin="{StaticResource PetMachSpace20}"
                                    Spacing="{StaticResource PetMachSpace4}"
                                    VerticalOptions="End">
                                    <Label
                                        SemanticProperties.HeadingLevel="Level2"
                                        Style="{StaticResource PetMachDisplayStyle}"
                                        Text="{Binding Name}"
                                        TextColor="{StaticResource PetMachTextOnColor}" />
                                    <Label
                                        Style="{StaticResource PetMachBodyStyle}"
                                        Text="{Binding Breed}"
                                        TextColor="{StaticResource PetMachTextOnStrong}" />
                                    <Label
                                        Style="{StaticResource PetMachBodySmallStyle}"
                                        Text="{Binding Region, StringFormat='Região: {0}'}"
                                        TextColor="{StaticResource PetMachTextOnStrong}" />
                                    <HorizontalStackLayout Spacing="{StaticResource PetMachSpace8}">
                                        <Border Style="{StaticResource PetMachChipStyle}">
                                            <Label
                                                Style="{StaticResource PetMachBadgeLabelStyle}"
                                                Text="{Binding Temperament}" />
                                        </Border>
                                        <Border
                                            IsVisible="{Binding VaccinationUpToDate}"
                                            Style="{StaticResource PetMachSelectedChipStyle}">
                                            <Label
                                                Style="{StaticResource PetMachBadgeLabelStyle}"
                                                Text="Vacinação em dia"
                                                TextColor="{StaticResource PetMachPrimary}" />
                                        </Border>
                                    </HorizontalStackLayout>
                                </VerticalStackLayout>
                            </Grid>
                        </Border>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="{StaticResource PetMachSpace12}">
                            <Button
                                AutomationId="{Binding DogId, StringFormat='DiscoveryPass_{0}'}"
                                Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.PassCommand}"
                                CommandParameter="{Binding .}"
                                SemanticProperties.Description="{Binding Name, StringFormat='Ignorar o perfil de {0}'}"
                                SemanticProperties.Hint="O perfil será removido somente após a confirmação do servidor"
                                Style="{StaticResource PetMachSecondaryButtonStyle}"
                                Text="Ignorar" />
                            <Button
                                Grid.Column="1"
                                AutomationId="{Binding DogId, StringFormat='DiscoveryLike_{0}'}"
                                Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.LikeCommand}"
                                CommandParameter="{Binding .}"
                                SemanticProperties.Description="{Binding Name, StringFormat='Curtir o perfil de {0}'}"
                                SemanticProperties.Hint="Envia uma curtida e informa se houve match"
                                Style="{StaticResource PetMachPrimaryButtonStyle}"
                                Text="Curtir" />
                        </Grid>
                        <Button
                            AutomationId="{Binding DogId, StringFormat='DiscoveryBlock_{0}'}"
                            Command="{Binding Source={x:Reference RootPage}, Path=BindingContext.BlockCommand}"
                            CommandParameter="{Binding .}"
                            SemanticProperties.Description="{Binding Name, StringFormat='Bloquear o tutor de {0}'}"
                            SemanticProperties.Hint="Oculta os perfis do tutor e encerra conexões ativas"
                            Style="{StaticResource PetMachDestructiveButtonStyle}"
                            Text="Bloquear este tutor" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator
            Grid.Row="3"
            AutomationId="DiscoveryPaginationProgress"
            IsRunning="{Binding IsPaging}"
            IsVisible="{Binding IsPaging}"
            SemanticProperties.Description="Carregando mais sugestões"
            Style="{StaticResource PetMachLoadingIndicatorStyle}" />

        <VerticalStackLayout
            Grid.Row="4"
            Spacing="{StaticResource PetMachSpace8}">
            <components:StateView
                AutomationId="DiscoverySuccessFeedback"
                IsVisible="{Binding HasSuccessFeedback}"
                Kind="Success"
                Message="{Binding StatusMessage}"
                SemanticProperties.Description="{Binding StatusMessage}"
                Title="Ação concluída" />
            <components:StateView
                AutomationId="DiscoveryErrorFeedback"
                IsVisible="{Binding HasErrorFeedback}"
                Kind="Error"
                Message="{Binding StatusMessage}"
                SemanticProperties.Description="{Binding StatusMessage}"
                Title="Ação não concluída" />
            <Label
                HorizontalTextAlignment="Center"
                SemanticProperties.Description="Sua localização exata nunca é compartilhada"
                Style="{StaticResource PetMachCaptionStyle}"
                Text="Sua localização exata nunca é compartilhada." />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
