<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PetMach.Mobile.DogsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:PetMach.Mobile.Components"
    BackgroundColor="{StaticResource PetMachBackground}"
    Title="Meus cães">
    <Grid Padding="24" RowDefinitions="Auto,Auto,*,Auto,Auto" RowSpacing="{StaticResource PetMachSpace16}">
        <Label Style="{StaticResource PetMachPageTitleStyle}" Text="Meus cães" />
        <Label Grid.Row="1" Style="{StaticResource PetMachBodyStyle}" Text="Perfis cadastrados na sua conta." />
        <CollectionView Grid.Row="2" ItemsSource="{Binding Dogs}">
            <CollectionView.EmptyView>
                <components:StateView
                    Kind="Empty"
                    Message="Cadastre seu primeiro pet para começar a criar conexões."
                    Title="Nenhum pet cadastrado" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,12" Style="{StaticResource PetMachCardStyle}">
                        <VerticalStackLayout Spacing="{StaticResource PetMachSpace4}">
                            <Label Style="{StaticResource PetMachCardTitleStyle}" Text="{Binding Name}" />
                            <Label Style="{StaticResource PetMachBodySmallStyle}" Text="{Binding Breed}" />
                            <Label Style="{StaticResource PetMachCaptionStyle}" Text="{Binding Temperament}" />
                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
        <ActivityIndicator
            Grid.Row="3"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            Style="{StaticResource PetMachLoadingIndicatorStyle}" />
        <VerticalStackLayout Grid.Row="4" Spacing="{StaticResource PetMachSpace8}">
            <Button Command="{Binding AddDogCommand}" Style="{StaticResource PetMachPrimaryButtonStyle}" Text="Cadastrar novo pet" />
            <Label HorizontalTextAlignment="Center" Style="{StaticResource PetMachErrorTextStyle}" Text="{Binding StatusMessage}" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>
