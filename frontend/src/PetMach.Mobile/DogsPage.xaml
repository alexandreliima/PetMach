<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PetMach.Mobile.DogsPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:PetMach.Mobile.Components"
    BackgroundColor="{StaticResource PetMachBackground}"
    Shell.NavBarIsVisible="False"
    Title="Perfil do pet">
    <Grid>
        <components:StateView
            Margin="{StaticResource PetMachPagePadding}"
            HorizontalOptions="Fill"
            IsVisible="{Binding Presentation.IsLoading, Source={x:Reference RootPage}}"
            Kind="Loading"
            Message="Reunindo as informações do perfil com segurança."
            SemanticProperties.Description="Carregando o perfil do pet"
            Title="Carregando perfil"
            VerticalOptions="Center" />

        <VerticalStackLayout
            Margin="{StaticResource PetMachPagePadding}"
            IsVisible="{Binding Presentation.HasError, Source={x:Reference RootPage}}"
            Spacing="{StaticResource PetMachSpace16}"
            VerticalOptions="Center">
            <components:StateView
                Kind="Error"
                Message="{Binding Presentation.ErrorMessage, Source={x:Reference RootPage}}"
                SemanticProperties.Description="Falha ao carregar o perfil do pet"
                Title="Não foi possível abrir o perfil" />
            <Button
                AutomationId="PetProfileRetryButton"
                Clicked="RetryClicked"
                SemanticProperties.Hint="Tenta carregar o perfil novamente"
                Style="{StaticResource PetMachPrimaryButtonStyle}"
                Text="Tentar novamente" />
        </VerticalStackLayout>

        <VerticalStackLayout
            Margin="{StaticResource PetMachPagePadding}"
            IsVisible="{Binding Presentation.ShowNoProfile, Source={x:Reference RootPage}}"
            Spacing="{StaticResource PetMachSpace16}"
            VerticalOptions="Center">
            <components:StateView
                Kind="Empty"
                Message="Cadastre as informações do seu primeiro companheiro para começar."
                SemanticProperties.Description="Nenhum perfil de pet cadastrado"
                Title="Nenhum perfil cadastrado" />
            <Button
                AutomationId="PetProfileAddFirstButton"
                Command="{Binding AddDogCommand}"
                SemanticProperties.Hint="Abre o cadastro de um novo pet"
                Style="{StaticResource PetMachPrimaryButtonStyle}"
                Text="Cadastrar pet" />
            <Button
                AutomationId="PetProfilePublicPreviewEmptyButton"
                Clicked="ShowVisitorClicked"
                SemanticProperties.Hint="Exibe uma demonstração de perfil público"
                Style="{StaticResource PetMachGhostButtonStyle}"
                Text="Visualizar exemplo público" />
        </VerticalStackLayout>

        <ScrollView
            x:Name="ProfileScroll"
            IsVisible="{Binding Presentation.ShowContent, Source={x:Reference RootPage}}">
            <VerticalStackLayout
                x:Name="ProfileContent"
                Padding="20,24,20,36"
                Spacing="{StaticResource PetMachSpace24}">
                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource PetMachSpace12}">
                    <components:SectionHeaderView
                        Eyebrow="{Binding Presentation.ModeLabel, Source={x:Reference RootPage}}"
                        Subtitle="Informações organizadas para conexões mais seguras."
                        Title="Perfil do pet" />
                    <Button
                        Grid.Column="1"
                        AutomationId="PetProfilePublicPreviewButton"
                        Clicked="ShowVisitorClicked"
                        IsVisible="{Binding Presentation.IsOwnerMode, Source={x:Reference RootPage}}"
                        SemanticProperties.Hint="Mostra como o perfil aparece publicamente"
                        Style="{StaticResource PetMachGhostButtonStyle}"
                        Text="Ver público" />
                    <Button
                        Grid.Column="1"
                        AutomationId="PetProfileOwnerModeButton"
                        Clicked="ShowOwnerClicked"
                        IsVisible="{Binding Presentation.IsVisitorMode, Source={x:Reference RootPage}}"
                        SemanticProperties.Hint="Retorna ao perfil privado do seu pet"
                        Style="{StaticResource PetMachGhostButtonStyle}"
                        Text="Meu perfil" />
                </Grid>

                <VerticalStackLayout
                    IsVisible="{Binding Presentation.IsOwnerMode, Source={x:Reference RootPage}}"
                    Spacing="{StaticResource PetMachSpace8}">
                    <Label Style="{StaticResource PetMachFieldLabelStyle}" Text="Pet selecionado" />
                    <Picker
                        x:Name="PetPicker"
                        AutomationId="PetProfileSelector"
                        ItemDisplayBinding="{Binding Name}"
                        ItemsSource="{Binding Dogs}"
                        SelectedIndexChanged="PetSelectionChanged"
                        SemanticProperties.Hint="Seleciona um dos seus pets cadastrados"
                        Title="Selecione o pet" />
                </VerticalStackLayout>

                <Border
                    AutomationId="PetProfileHero"
                    HeightRequest="430"
                    Padding="0"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 28">
                    <Grid>
                        <Image
                            Aspect="AspectFill"
                            SemanticProperties.Description="{Binding Presentation.Name, Source={x:Reference RootPage}, StringFormat='Foto principal de {0}'}"
                            Source="{Binding Presentation.HeroImageSource, Source={x:Reference RootPage}}" />
                        <BoxView
                            BackgroundColor="{StaticResource PetMachSurfaceStrong}"
                            HeightRequest="190"
                            Opacity="0.82"
                            VerticalOptions="End" />
                        <Border
                            Margin="{StaticResource PetMachSpace16}"
                            BackgroundColor="{StaticResource PetMachSurface}"
                            HorizontalOptions="Start"
                            Padding="{StaticResource PetMachChipPadding}"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 18"
                            VerticalOptions="Start">
                            <Label
                                Style="{StaticResource PetMachBadgeLabelStyle}"
                                Text="{Binding Presentation.ModeLabel, Source={x:Reference RootPage}}" />
                        </Border>
                        <VerticalStackLayout
                            Margin="{StaticResource PetMachSpace20}"
                            Spacing="{StaticResource PetMachSpace4}"
                            VerticalOptions="End">
                            <Label
                                SemanticProperties.HeadingLevel="Level1"
                                Style="{StaticResource PetMachDisplayStyle}"
                                Text="{Binding Presentation.Name, Source={x:Reference RootPage}}"
                                TextColor="{StaticResource PetMachTextOnColor}" />
                            <Label TextColor="{StaticResource PetMachTextOnStrong}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Presentation.Species, Source={x:Reference RootPage}}" />
                                        <Span Text=" · " />
                                        <Span Text="{Binding Presentation.Breed, Source={x:Reference RootPage}}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label TextColor="{StaticResource PetMachTextOnStrong}">
                                <Label.FormattedText>
                                    <FormattedString>
                                        <Span Text="{Binding Presentation.Age, Source={x:Reference RootPage}}" />
                                        <Span Text=" · " />
                                        <Span Text="{Binding Presentation.Sex, Source={x:Reference RootPage}}" />
                                    </FormattedString>
                                </Label.FormattedText>
                            </Label>
                            <Label
                                Style="{StaticResource PetMachCaptionStyle}"
                                Text="{Binding Presentation.ApproximateLocation, Source={x:Reference RootPage}}"
                                TextColor="{StaticResource PetMachTextOnStrong}" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <components:StateView
                    IsVisible="{Binding Presentation.HasNoMainPhoto, Source={x:Reference RootPage}}"
                    Kind="Warning"
                    Message="O placeholder protege a experiência até uma foto ser adicionada pelo fluxo existente."
                    Title="Perfil sem foto principal" />

                <components:StateView
                    IsVisible="{Binding Presentation.ShowIncompleteOwner, Source={x:Reference RootPage}}"
                    Kind="Warning"
                    Message="Uma foto e uma descrição ajudam outros tutores a conhecer melhor seu pet."
                    Title="Perfil incompleto" />

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Galeria" />
                    <FlexLayout
                        AlignItems="Start"
                        BindableLayout.ItemsSource="{Binding Presentation.Gallery, Source={x:Reference RootPage}}"
                        Direction="Row"
                        IsVisible="{Binding Presentation.HasGallery, Source={x:Reference RootPage}}"
                        JustifyContent="Start"
                        Wrap="Wrap">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border
                                    HeightRequest="112"
                                    Margin="0,0,8,8"
                                    Padding="0"
                                    StrokeThickness="0"
                                    StrokeShape="RoundRectangle 18"
                                    WidthRequest="112">
                                    <Image
                                        Aspect="AspectFill"
                                        SemanticProperties.Description="Miniatura da galeria do pet"
                                        Source="{Binding .}" />
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                    <components:StateView
                        IsVisible="{Binding Presentation.HasNoGallery, Source={x:Reference RootPage}}"
                        Kind="Empty"
                        Message="As miniaturas aparecerão aqui quando existirem fotos disponíveis."
                        Title="Galeria vazia" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Sobre" />
                    <Border IsVisible="{Binding Presentation.HasDescription, Source={x:Reference RootPage}}" Style="{StaticResource PetMachCardStyle}">
                        <Label Style="{StaticResource PetMachBodyStyle}" Text="{Binding Presentation.Description, Source={x:Reference RootPage}}" />
                    </Border>
                    <components:StateView
                        IsVisible="{Binding Presentation.HasNoDescription, Source={x:Reference RootPage}}"
                        Kind="Empty"
                        Message="Ainda não há uma apresentação para este pet."
                        Title="Sem descrição" />
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Características" />
                    <FlexLayout
                        AlignItems="Start"
                        BindableLayout.ItemsSource="{Binding Presentation.Characteristics, Source={x:Reference RootPage}}"
                        Direction="Row"
                        JustifyContent="Start"
                        Wrap="Wrap">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,8,8" Style="{StaticResource PetMachChipStyle}">
                                    <Label Style="{StaticResource PetMachBadgeLabelStyle}" Text="{Binding .}" />
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Personalidade" />
                    <FlexLayout
                        AlignItems="Start"
                        BindableLayout.ItemsSource="{Binding Presentation.Personality, Source={x:Reference RootPage}}"
                        Direction="Row"
                        JustifyContent="Start"
                        Wrap="Wrap">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border Margin="0,0,8,8" Style="{StaticResource PetMachSelectedChipStyle}">
                                    <Label
                                        Style="{StaticResource PetMachBadgeLabelStyle}"
                                        Text="{Binding .}"
                                        TextColor="{StaticResource PetMachPrimary}" />
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Saúde" />
                    <Border Style="{StaticResource PetMachCardStyle}">
                        <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                            <Label Style="{StaticResource PetMachCardTitleStyle}" Text="Resumo permitido" />
                            <Label Style="{StaticResource PetMachBodySmallStyle}" Text="{Binding Presentation.HealthSummary, Source={x:Reference RootPage}}" />
                            <Label
                                IsVisible="{Binding Presentation.IsVisitorMode, Source={x:Reference RootPage}}"
                                Style="{StaticResource PetMachCaptionStyle}"
                                Text="Detalhes médicos e comprovantes nunca são exibidos publicamente." />
                        </VerticalStackLayout>
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Compatibilidade" />
                    <Border Style="{StaticResource PetMachCardStyle}">
                        <Label Style="{StaticResource PetMachBodySmallStyle}" Text="{Binding Presentation.CompatibilitySummary, Source={x:Reference RootPage}}" />
                    </Border>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Estatísticas" />
                    <HorizontalStackLayout
                        BindableLayout.ItemsSource="{Binding Presentation.Statistics, Source={x:Reference RootPage}}"
                        HorizontalOptions="Center"
                        Spacing="{StaticResource PetMachSpace8}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border MinimumWidthRequest="96" Style="{StaticResource PetMachCardStyle}">
                                    <VerticalStackLayout Spacing="{StaticResource PetMachSpace4}">
                                        <Label
                                            HorizontalTextAlignment="Center"
                                            Style="{StaticResource PetMachSectionTitleStyle}"
                                            Text="{Binding Value}" />
                                        <Label
                                            HorizontalTextAlignment="Center"
                                            Style="{StaticResource PetMachCaptionStyle}"
                                            Text="{Binding Label}" />
                                    </VerticalStackLayout>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </HorizontalStackLayout>
                </VerticalStackLayout>

                <VerticalStackLayout Spacing="{StaticResource PetMachSpace12}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Linha do tempo" />
                    <VerticalStackLayout
                        BindableLayout.ItemsSource="{Binding Presentation.Timeline, Source={x:Reference RootPage}}"
                        IsVisible="{Binding Presentation.HasTimeline, Source={x:Reference RootPage}}"
                        Spacing="{StaticResource PetMachSpace8}">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource PetMachCardStyle}">
                                    <Grid ColumnDefinitions="*,Auto" ColumnSpacing="{StaticResource PetMachSpace12}">
                                        <VerticalStackLayout Spacing="{StaticResource PetMachSpace4}">
                                            <Label Style="{StaticResource PetMachCardTitleStyle}" Text="{Binding Title}" />
                                            <Label Style="{StaticResource PetMachBodySmallStyle}" Text="{Binding Description}" />
                                        </VerticalStackLayout>
                                        <Label Grid.Column="1" Style="{StaticResource PetMachCaptionStyle}" Text="{Binding When}" />
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </VerticalStackLayout>
                    <components:StateView
                        IsVisible="{Binding Presentation.HasNoTimeline, Source={x:Reference RootPage}}"
                        Kind="Empty"
                        Message="Encontros e atualizações futuras poderão aparecer nesta área."
                        Title="Sem histórico" />
                </VerticalStackLayout>

                <VerticalStackLayout
                    IsVisible="{Binding Presentation.IsOwnerMode, Source={x:Reference RootPage}}"
                    Spacing="{StaticResource PetMachSpace8}">
                    <Label
                        SemanticProperties.HeadingLevel="Level2"
                        Style="{StaticResource PetMachSectionTitleStyle}"
                        Text="Gerenciamento" />
                    <Button
                        AutomationId="PetProfileAddAnotherButton"
                        Command="{Binding AddDogCommand}"
                        SemanticProperties.Hint="Abre o cadastro de outro pet"
                        Style="{StaticResource PetMachSecondaryButtonStyle}"
                        Text="Cadastrar outro pet" />
                    <Label
                        HorizontalTextAlignment="Center"
                        Style="{StaticResource PetMachCaptionStyle}"
                        Text="A edição do perfil será exibida quando existir um comando de edição no fluxo atual." />
                </VerticalStackLayout>

                <Border
                    IsVisible="{Binding Presentation.IsVisitorMode, Source={x:Reference RootPage}}"
                    Style="{StaticResource PetMachCardStyle}">
                    <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                        <Label Style="{StaticResource PetMachCardTitleStyle}" Text="Ações públicas" />
                        <Label
                            Style="{StaticResource PetMachBodySmallStyle}"
                            Text="Curtidas, bloqueios e conexões continuam disponíveis somente no fluxo Descobrir." />
                    </VerticalStackLayout>
                </Border>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>
