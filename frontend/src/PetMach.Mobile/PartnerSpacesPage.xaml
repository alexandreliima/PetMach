<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="PetMach.Mobile.PartnerSpacesPage" xmlns="http://schemas.microsoft.com/dotnet/2021/maui" xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml" Title="Espaços parceiros" BackgroundColor="{StaticResource Surface}">
    <Grid Padding="24" RowDefinitions="Auto,Auto,*,Auto,Auto,Auto" RowSpacing="12">
        <Label FontAttributes="Bold" FontSize="30" Text="Espaços parceiros" />
        <Grid Grid.Row="1" ColumnDefinitions="*,*,Auto" ColumnSpacing="8"><Entry Placeholder="Cidade" Text="{Binding City}" /><Entry Grid.Column="1" Placeholder="Estado" Text="{Binding State}" /><Button Grid.Column="2" Command="{Binding LoadCommand}" Text="Buscar" /></Grid>
        <CollectionView Grid.Row="2" ItemsSource="{Binding Spaces}" EmptyView="Nenhum espaço encontrado."><CollectionView.ItemTemplate><DataTemplate><Border Margin="0,0,0,12" Padding="16" BackgroundColor="White" Stroke="#E7D8CD" StrokeShape="RoundRectangle 16"><VerticalStackLayout><Label FontAttributes="Bold" FontSize="20" Text="{Binding Name}" /><Label Text="{Binding EstablishmentName}" /><Label Text="{Binding Description}" /><Label Text="{Binding InformationalPrice, StringFormat='Valor informativo: {0:C}'}" /><Label Text="{Binding City, StringFormat='Cidade: {0}'}" /></VerticalStackLayout></Border></DataTemplate></CollectionView.ItemTemplate></CollectionView>
        <Picker Grid.Row="3" Title="Consultar horários de um espaço" ItemsSource="{Binding Spaces}" ItemDisplayBinding="{Binding Name}" SelectedItem="{Binding SelectedSpace}" />
        <CollectionView Grid.Row="4" HeightRequest="130" ItemsSource="{Binding Availability}" EmptyView="Selecione um espaço para consultar horários."><CollectionView.ItemTemplate><DataTemplate><Border Margin="0,0,0,6" Padding="10" BackgroundColor="White" Stroke="#E7D8CD" StrokeShape="RoundRectangle 12"><Label Text="{Binding Period}" /></Border></DataTemplate></CollectionView.ItemTemplate></CollectionView>
        <Label Grid.Row="5" Text="{Binding StatusMessage}" HorizontalTextAlignment="Center" />
    </Grid>
</ContentPage>
