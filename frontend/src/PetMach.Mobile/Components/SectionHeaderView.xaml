<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="PetMach.Mobile.Components.SectionHeaderView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
        <Label
            Style="{StaticResource PetMachEyebrowStyle}"
            Text="{Binding Eyebrow, Source={x:Reference Root}}" />
        <Label
            Style="{StaticResource PetMachPageTitleStyle}"
            Text="{Binding Title, Source={x:Reference Root}}" />
        <Label
            Style="{StaticResource PetMachBodyStyle}"
            Text="{Binding Subtitle, Source={x:Reference Root}}" />
    </VerticalStackLayout>
</ContentView>
