<?xml version="1.0" encoding="utf-8" ?>
<ContentView
    x:Class="PetMach.Mobile.Components.PetAvatarView"
    x:Name="Root"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">
    <Border
        HeightRequest="{Binding Size, Source={x:Reference Root}}"
        Padding="0"
        Style="{StaticResource PetMachAvatarBorderStyle}"
        WidthRequest="{Binding Size, Source={x:Reference Root}}">
        <Grid>
            <Image
                Margin="{StaticResource PetMachSpace12}"
                Aspect="AspectFit"
                Opacity="0.72"
                Source="petmatch_logo.svg" />
            <Image
                Aspect="AspectFill"
                Source="{Binding Source, Source={x:Reference Root}}" />
        </Grid>
    </Border>
</ContentView>
