<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="PetMach.Mobile.AboutPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:components="clr-namespace:PetMach.Mobile.Components"
    Title="Sobre o PetMatch">
    <ScrollView>
        <VerticalStackLayout
            Padding="{StaticResource PetMachPagePadding}"
            Spacing="{StaticResource PetMachSpace20}">
            <components:SectionHeaderView
                Eyebrow="SOBRE O PETMATCH"
                Subtitle="Uma plataforma para pets e tutores encontrarem companhia, passeios e serviços com mais segurança."
                Title="Boas experiências começam com cuidado." />

            <Border Style="{StaticResource PetMachStrongCardStyle}">
                <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                    <Label
                        AutomationId="AboutAppName"
                        Style="{StaticResource PetMachCardTitleStyle}"
                        Text="{Binding AppName}"
                        TextColor="{StaticResource PetMachTextOnColor}" />
                    <Label
                        AutomationId="AboutVersion"
                        SemanticProperties.Description="{Binding VersionDescription}"
                        Style="{StaticResource PetMachBodySmallStyle}"
                        Text="{Binding VersionDescription}"
                        TextColor="{StaticResource PetMachTextOnStrong}" />
                    <Label
                        Style="{StaticResource PetMachCaptionStyle}"
                        Text="Informações obtidas diretamente deste aplicativo."
                        TextColor="{StaticResource PetMachTextOnStrong}" />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource PetMachCardStyle}">
                <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                    <Label Style="{StaticResource PetMachCardTitleStyle}" Text="Descoberta compatível" />
                    <Label Style="{StaticResource PetMachBodySmallStyle}" Text="Encontre pets considerando porte, energia, temperamento e objetivos de socialização." />
                </VerticalStackLayout>
            </Border>
            <Border Style="{StaticResource PetMachCardStyle}">
                <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                    <Label Style="{StaticResource PetMachCardTitleStyle}" Text="Conexões com consentimento" />
                    <Label Style="{StaticResource PetMachBodySmallStyle}" Text="A conversa é liberada quando os dois tutores demonstram interesse." />
                </VerticalStackLayout>
            </Border>
            <Border Style="{StaticResource PetMachCardStyle}">
                <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                    <Label Style="{StaticResource PetMachCardTitleStyle}" Text="Saúde organizada" />
                    <Label Style="{StaticResource PetMachBodySmallStyle}" Text="Registre vacinas e cuidados sem tornar informações sensíveis públicas." />
                </VerticalStackLayout>
            </Border>
            <Border Style="{StaticResource PetMachCardStyle}">
                <VerticalStackLayout Spacing="{StaticResource PetMachSpace8}">
                    <Label Style="{StaticResource PetMachCardTitleStyle}" Text="Encontros e parceiros" />
                    <Label Style="{StaticResource PetMachBodySmallStyle}" Text="Organize encontros e encontre espaços parceiros para momentos especiais." />
                </VerticalStackLayout>
            </Border>

            <Border Style="{StaticResource PetMachWarningStateStyle}">
                <Label
                    Style="{StaticResource PetMachBodySmallStyle}"
                    Text="Sua localização exata e os dados privados de saúde não são exibidos publicamente." />
            </Border>
            <VerticalStackLayout
                IsVisible="{Binding ShowPublicActions}"
                Spacing="{StaticResource PetMachSpace12}">
                <Button
                    AutomationId="AboutCreateAccountButton"
                    Command="{Binding OpenRegistrationCommand}"
                    SemanticProperties.Hint="Abre o cadastro de uma nova conta"
                    Style="{StaticResource PetMachPrimaryButtonStyle}"
                    Text="Criar minha conta" />
                <Button
                    AutomationId="AboutLoginButton"
                    Command="{Binding OpenLoginCommand}"
                    SemanticProperties.Hint="Abre a tela de login"
                    Style="{StaticResource PetMachSecondaryButtonStyle}"
                    Text="Já tenho uma conta" />
            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
